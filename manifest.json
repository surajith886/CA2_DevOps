{
  "$schema": "https://json.schemastore.org/web-manifest",
  "name": "Student Feedback Form - DevOps Assignment",
  "short_name": "Feedback Form",
  "description": "Accessible modern student feedback registration form",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#667eea",
  "theme_color": "#667eea",
  "categories": ["education", "productivity", "form"],
  "icons": [
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable any"
    },
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable any"
